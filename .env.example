# ─────────────────────────────────────────────────────────────────────────────
# Fortuna Brand Health Tracker — Environment Variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Phase 1) ────────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase, Railway, Neon, or local)
# Example Supabase: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Without this, the app runs in demo mode with sample data.
DATABASE_URL=""

# ── Clerk Authentication (Phase 1) ───────────────────────────────────────────
# Create a free account at https://clerk.com → create an application → copy keys
# Without these, the app runs without authentication (demo mode).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Clerk redirect URLs (after sign-in / sign-up)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Analytics Service (Phase 3) ───────────────────────────────────────────────
# URL of the Python FastAPI analytics microservice
# Run locally: cd analytics-service && uvicorn main:app --reload
# Without this, DJ normalization and KPI calculation use client-side estimates.
ANALYTICS_SERVICE_URL=http://localhost:8000

# ── AI Features (Phase 5) ─────────────────────────────────────────────────────
# Anthropic Claude API — for AI CEP generator, trend alerts, category twins
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=""

# ── Email Distribution (Phase 6) ─────────────────────────────────────────────
# Option A — Resend (recommended): https://resend.com
RESEND_API_KEY=""
EMAIL_FROM="survey@yourdomain.com"

# Option B — SMTP (nodemailer fallback)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# ── WhatsApp Distribution (Phase 6) ──────────────────────────────────────────
# Meta WhatsApp Business Cloud API
# Setup: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
# 1. Create Meta App → WhatsApp product → get Phone Number ID
# 2. Generate a permanent System User token
# 3. Submit a message template named below for approval
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_TEMPLATE_NAME="survey_invite"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="fortuna-webhook-verify"

# ── App URL (for internal API calls) ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Deployment ────────────────────────────────────────────────────────────────
# Set automatically by Vercel — do not set manually
# VERCEL_URL=
